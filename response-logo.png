:root{--gold:#c69653;--green:#6ebe44;--black:#050505;--text:#1d232b;--muted:#68707a;--line:#e8e5df;--soft:#f8f6f2;--white:#fff;--red:#c9202d}*{box-sizing:border-box}body{margin:0;font-family:Arial,Helvetica,sans-serif;color:var(--text);background:var(--white);line-height:1.55}.skip{position:absolute;left:-999px;top:auto}.skip:focus{left:1rem;top:1rem;background:#fff;padding:.5rem;z-index:10}.site-header{background:#000;border-bottom:4px solid var(--gold)}.nav-wrap{max-width:1120px;margin:auto;padding:18px 22px;display:flex;align-items:center;justify-content:space-between;gap:20px}.brand{display:flex;align-items:center;gap:14px;color:#fff;text-decoration:none}.brand img{max-height:58px;max-width:430px;width:100%;object-fit:contain}.brand-title{font-weight:700;letter-spacing:.04em;color:#fff}.nav{display:flex;gap:18px;flex-wrap:wrap}.nav a{color:#fff;text-decoration:none;font-weight:600}.nav a:hover{color:var(--gold)}.container{max-width:1120px;margin:auto;padding:0 22px}.hero{background:linear-gradient(180deg,#0b0b0b,#1d1a16);color:#fff;padding:70px 0}.hero-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:40px;align-items:center}.eyebrow{color:var(--gold);font-weight:700;text-transform:uppercase;letter-spacing:.12em;font-size:.85rem}.hero h1,.page-title{font-size:clamp(2rem,5vw,4.2rem);line-height:1.05;margin:.35em 0}.hero p{font-size:1.15rem;color:#eee}.panel{background:#fff;color:var(--text);border-radius:22px;padding:28px;box-shadow:0 16px 40px rgba(0,0,0,.25)}.panel img{width:100%;height:auto}.section{padding:58px 0}.section.alt{background:var(--soft)}h2{font-size:clamp(1.6rem,3vw,2.4rem);margin:0 0 16px}.grid{display:grid;gap:22px}.team-grid{grid-template-columns:repeat(auto-fit,minmax(230px,1fr))}.company-grid{grid-template-columns:repeat(auto-fit,minmax(240px,1fr))}.card{background:#fff;border:1px solid var(--line);border-radius:18px;padding:24px;box-shadow:0 8px 22px rgba(0,0,0,.06)}.card h3{margin:.2rem 0 .25rem}.muted{color:var(--muted)}.btn{display:inline-flex;align-items:center;justify-content:center;gap:.4rem;text-decoration:none;border-radius:999px;padding:12px 18px;font-weight:700;border:2px solid transparent;margin:6px 6px 6px 0}.btn.gold{background:var(--gold);color:#fff}.btn.black{background:#000;color:#fff}.btn.outline{background:#fff;color:#000;border-color:#000}.btn.green{background:var(--green);color:#fff}.btn.red{background:var(--red);color:#fff}.button-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px}.page-hero{background:var(--soft);padding:54px 0;border-bottom:1px solid var(--line)}.profile{display:grid;grid-template-columns:.85fr 1.15fr;gap:34px;align-items:start}.profile-card{text-align:center}.initials{width:120px;height:120px;border-radius:50%;background:#000;color:var(--gold);display:grid;place-items:center;font-size:2.3rem;font-weight:800;margin:0 auto 18px}.contact-list{display:grid;gap:10px}.contact-list a{color:#000;font-weight:700}.logo-card img{max-height:75px;max-width:100%;object-fit:contain;margin-bottom:14px}.footer{background:#000;color:#fff;padding:34px 22px;text-align:center;border-top:4px solid var(--gold)}.footer .small{color:#d8d8d8;font-size:.92rem}.badge{display:inline-block;border-left:5px solid var(--gold);padding-left:12px;font-weight:700}.notice{background:#fff7ea;border:1px solid #ead7b8;border-radius:16px;padding:18px} @media(max-width:760px){.nav-wrap{display:block}.brand{margin-bottom:14px}.hero-grid,.profile{grid-template-columns:1fr}.hero{padding:46px 0}.brand img{max-height:48px}.nav{gap:12px}.btn{width:100%;margin:6px 0}.button-row{display:block}}
